# ===== AWS =====
# AgentCore Payments supports: us-east-1, us-west-2, eu-central-1, ap-southeast-2
AWS_REGION=us-west-2

# IAM role ARN used by the Payment Manager as its service role.
# Must trust bedrock-agentcore.amazonaws.com. See README for the trust policy.
PAYMENTS_ROLE_ARN=arn:aws:iam::123456789012:role/AgentCorePaymentsServiceRole

# ===== Payment provider =====
# Which wallet provider to use. Default "coinbase" (Coinbase CDP). Alternative
# "privy" uses Stripe + Privy. Testnet flow (Base Sepolia, Circle faucet) is
# identical for both; Privy's key differentiator (fiat onramp via Stripe card)
# is disabled in testnet anyway.
PAYMENT_PROVIDER=coinbase

# ----- Coinbase CDP credentials (required when PAYMENT_PROVIDER=coinbase) -----
# See README section "Coinbase CDP credentials" for exact steps.
#   CDP_API_KEY_ID / CDP_API_KEY_SECRET:
#     https://portal.cdp.coinbase.com/  -> API Keys -> Create API key
#   CDP_WALLET_SECRET (on a DIFFERENT page):
#     https://portal.cdp.coinbase.com/products/server-wallets -> Generate
# Also required: Project -> Wallet -> Embedded Wallets -> Policies ->
#   enable "Delegated signing".
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=
CDP_WALLET_SECRET=

# ----- Privy credentials (required when PAYMENT_PROVIDER=privy) -----
# Get these from https://dashboard.privy.io/. Create a DEDICATED Privy app
# for AgentCore (don't reuse one used by other products).
#   PRIVY_APP_ID / PRIVY_APP_SECRET: app settings
#   PRIVY_AUTH_ID / PRIVY_AUTH_PRIVATE_KEY:
#     Wallet Infrastructure -> Authorization -> New Key
# IMPORTANT: the private key Privy hands you starts with "wallet-auth:" --
# setup.py strips the prefix automatically, but you can also strip it here.
PRIVY_APP_ID=
PRIVY_APP_SECRET=
PRIVY_AUTH_ID=
PRIVY_AUTH_PRIVATE_KEY=

# ===== User identity =====
# USER_ID is a stable identifier of the end user (any string you choose)
USER_ID=demo-user-001
# USER_EMAIL is linked to the embedded crypto wallet so the user can sign in
# to Coinbase WalletHub to top up and grant agent permissions.
USER_EMAIL=you@example.com

# ===== Demo configuration =====
# Names of AWS resources created by setup.py use this prefix.
RESOURCE_PREFIX=agentcore-payment-demo

# Paid x402 endpoint the agent will call. Default is the official AWS demo
# endpoint on Base Sepolia testnet — small fee, no real money.
PAID_URL=https://drvd12nxpcyd5.cloudfront.net/market-recap

# Blockchain network preferences (CAIP-2 IDs, comma-separated, in priority order).
# Default prioritizes Base Sepolia testnet.
NETWORK_PREFERENCES=base-sepolia,eip155:84532

# Payment session spending cap and expiry.
SESSION_MAX_USD=1.00
SESSION_EXPIRY_MINUTES=60

# ===== Populated by setup.py — do NOT edit manually =====
# These are written to .env.local automatically.
# PAYMENT_MANAGER_ARN=
# PAYMENT_CONNECTOR_ID=
# PAYMENT_CREDENTIAL_PROVIDER_ARN=
# PAYMENT_INSTRUMENT_ID=
# PAYMENT_SESSION_ID=
